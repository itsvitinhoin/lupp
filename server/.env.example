NODE_ENV=dev
PORT=3333
JWT_SECRET=lupp-server-jwt-secret
# Append ?schema=<name> to target a non-public Postgres schema.
DATABASE_URL=postgres://docker:docker@localhost:5433/lupp

# Public base URL of the SPA (OAuth redirects, billing callbacks)
LUPP_APP_URL=http://localhost:5173

# --- Asaas billing (routes return missing_asaas_api_key until set) ---
# ASAAS_API_KEY=
# sandbox (default) or production — the original edge functions ran with production
# ASAAS_ENVIRONMENT=sandbox
# ASAAS_WEBHOOK_TOKEN=

# --- Bunny Stream video hosting ---
# BUNNY_STREAM_LIBRARY_ID=
# BUNNY_STREAM_API_KEY=
# BUNNY_STREAM_CDN_HOSTNAME=

# --- Nuvemshop / Tiendanube ---
# NUVEMSHOP_APP_ID=34355
# NUVEMSHOP_CLIENT_ID=
# NUVEMSHOP_CLIENT_SECRET=
# NUVEMSHOP_STATE_SECRET=
# NUVEMSHOP_AUTHORIZE_BASE_URL=https://www.nuvemshop.com.br
# Script install extras (read directly from process.env by install-script):
# NUVEMSHOP_SCRIPT_ID=
# NUVEMSHOP_SCRIPT_AUTO_INSTALL=true
# NUVEMSHOP_USER_AGENT=
# SUPABASE_URL=            # legacy: forwarded to the storefront loader query

# --- Shopify ---
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# SHOPIFY_SCOPES=read_products,read_inventory,read_locations
# SHOPIFY_REDIRECT_URI=    # set in real deployments (falls back to <app>/api/integrations/shopify/oauth/callback)
# SHOPIFY_STATE_SECRET=
# SHOPIFY_APP_URL=
# SHOPIFY_CUSTOM_APPS_JSON=
# SHOPIFY_API_VERSION=2026-04

# --- Upzero ---
# UPZERO_API_BASE_URL=https://api.upzero.com.br

# --- Master console admin allowlist (comma-separated emails) ---
# MASTER_ADMIN_EMAILS=playluup@gmail.com
