{
  "name": "@workspace/lupp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0",
    "build": "npm run build:widget && npm run build:nubesdk && vite build --config vite.config.ts",
    "build:widget": "node build-widget.mjs",
    "build:nubesdk": "node build-nubesdk.mjs",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "start": "serve -s dist/public -l 3040",
    "typecheck": "tsc -p tsconfig.json --noEmit && npm run typecheck:widget",
    "typecheck:widget": "tsc -p widget-src/tsconfig.json"
  },
  "devDependencies": {
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
